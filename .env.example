# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional site metadata for OpenRouter rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=D3-AI Analytics

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Client (Vite) — publishable key only
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Privy — https://dashboard.privy.io
VITE_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
PRIVY_APP_SECRET=privy_app_secret_your-secret
# BNB Smart Chain RPC (optional — viem default used if unset)
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
# Optional: required for some Privy app configurations
# VITE_PRIVY_CLIENT_ID=your-privy-client-id
