# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional site metadata for OpenRouter rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=D3-AI Analytics

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Client (Vite) — publishable key only; calls Supabase Edge Function `union`
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Edge Function secrets (set via `supabase secrets set`, NOT in Netlify)
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_APP_SECRET=privy_app_secret_...
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
# PRIVY_LINE_KEY_QUORUM_ID=pz0hdt8qtma7uyhujq1hzdbw
# PRIVY_DAO_KEY_QUORUM_ID=company-multisig-key-quorum-id
# PRIVY_TREASURY_AUTH_PRIVATE_KEY=wallet-auth:<base64-pkcs8-private-key-from-dashboard>
# PRIVY_CHAIN_CAIP2=eip155:56

# Privy — https://dashboard.privy.io
VITE_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
PRIVY_APP_SECRET=privy_app_secret_your-secret
# Optional canonical public URL (fallback when window is unavailable). Leave unset to use current browser origin.
# VITE_APP_ORIGIN=https://d3.fi

# Demo line-leader wallet (matches supabase/seed.sql) — used for "演示账户" login
VITE_DEMO_WALLET_ADDRESS=0x1234567890abcdef1234567890abcdef12345678
# Edge Function: set DEMO_WALLET_ADDRESS to the same value; set DEMO_MODE_ENABLED=false to disable

# BNB Smart Chain RPC (optional — viem default used if unset)
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# Turnkey — https://www.turnkey.com (Edge Function secrets only, never VITE_)
# TURNKEY_ORGANIZATION_ID=your-org-id
# TURNKEY_API_PUBLIC_KEY=your-api-public-key
# TURNKEY_API_PRIVATE_KEY=your-api-private-key
# Path C co-signer: separate quorum member API key (NOT the same user as admin Passkey)
# TURNKEY_COSIGNER_API_PUBLIC_KEY=03b5fb7e...
# TURNKEY_COSIGNER_API_PRIVATE_KEY=...
# TURNKEY_TREASURY_ADDRESS=0x...  # company treasury on BSC (never expose to clients)
# TURNKEY_TREASURY_WALLET_ID=cec23fe6-...  # Turnkey wallet id for Policy / multisig
# If auto wallet creation is blocked by Policy (CONSENSUS_NEEDED), register manual wallets:
# TURNKEY_SETTLEMENT_ADDRESSES=0x...,0x...,0x...
# TURNKEY_SETTLEMENT_WALLET_IDS=uuid1,uuid2,uuid3
# TURNKEY_GAS_WALLET_ADDRESS=0x...
# TURNKEY_GAS_WALLET_ID=uuid
# TURNKEY_DEPOSITS_WALLET_ID=...   # optional: existing D3-Deposits HD wallet id (else auto-created)
# TURNKEY_DEPOSITS_WALLET_ADDRESS=0x...  # optional parent account address (index 0)
# TREASURY_DEV_MNEMONIC=test test ...  # dev only: HD wallets when Turnkey not configured

# Treasury pipeline (Edge Function secrets)
# SETTLEMENT_WALLET_COUNT=3
# SETTLEMENT_TO_TREASURY_MIN_USDT=100
# DEPOSIT_POOL_TARGET_SIZE=50
# DEPOSIT_POOL_MIN_AVAILABLE=10
# DEPOSIT_POOL_BATCH_SIZE=10
# TREASURY_CRON_SECRET=random-secret-for-cron-and-admin-bootstrap
# Setup cron (secret + pg_cron every 5min): npm run treasury:setup-cron
# Cron: POST /functions/v1/treasury/internal/run  Header: X-Treasury-Cron-Secret
# Bootstrap settlement+gas: POST /functions/v1/treasury/admin/bootstrap
# Bootstrap deposit pool (Turnkey HD: 1 parent wallet + createWalletAccounts):
#   npm run treasury:bootstrap-pool

# Optional: required for some Privy app configurations
# VITE_PRIVY_CLIENT_ID=your-privy-client-id
