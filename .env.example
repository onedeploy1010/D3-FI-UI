# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional site metadata for OpenRouter rankings
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=D3-AI Analytics

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
SUPABASE_SECRET_KEY=sb_secret_your-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Client (Vite) — publishable key only; calls Supabase Edge Function `union`
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Edge Function secrets (set via `supabase secrets set`, NOT in Netlify)
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_APP_SECRET=privy_app_secret_...
# PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
# PRIVY_LINE_KEY_QUORUM_ID=pz0hdt8qtma7uyhujq1hzdbw
# PRIVY_TREASURY_AUTH_PRIVATE_KEY=wallet-auth:<base64-pkcs8-private-key-from-dashboard>
# PRIVY_CHAIN_CAIP2=eip155:56

# Privy — https://dashboard.privy.io
VITE_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json
PRIVY_APP_SECRET=privy_app_secret_your-secret
# Optional canonical public URL (fallback when window is unavailable). Leave unset to use current browser origin.
# VITE_APP_ORIGIN=https://d3.fi

# Demo line-leader wallet (matches supabase/seed.sql) — used for "演示账户" login
VITE_DEMO_WALLET_ADDRESS=0x1234567890AbCdEf1234567890AbCdEf1234567890
# Edge Function: set DEMO_WALLET_ADDRESS to the same value; set DEMO_MODE_ENABLED=false to disable

# BNB Smart Chain RPC (optional — viem default used if unset)
# VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
# Optional: required for some Privy app configurations
# VITE_PRIVY_CLIENT_ID=your-privy-client-id
