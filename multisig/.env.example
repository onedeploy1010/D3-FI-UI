# D3 多签系统 — 环境变量
# 与主 App / admin-panel 共用同一个 Supabase 项目
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-or-anon-key>

# 管理员登录用的合成邮箱域（与 admin-panel 一致，用户只输用户名）
VITE_AUTH_DOMAIN=@d3.fi

# Turnkey 后台深链（用于「去 Turnkey 批准」跳转）。以实际 Turnkey 控制台 URL 为准。
VITE_TURNKEY_ORG_ID=<turnkey-organization-id>
VITE_TURNKEY_DASHBOARD_BASE=https://app.turnkey.com
